# App
APP_ENV=development
APP_NAME="Skill Intelligence System"
APP_VERSION=0.1.0
DEBUG=true

# Database
#
# For Neon (recommended):
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>/<db>?sslmode=require
#
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./skilldb.sqlite3

# Auth
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI (LLM fallback — leave blank for Week 1)
OPENAI_API_KEY=

# Redis — local (optional for now, only needed for LLM cache in Week 3)
REDIS_URL=redis://localhost:6379/0

# LangSmith / tracing (optional). Prefer LANGSMITH_*; legacy LANGCHAIN_* still works.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=skill-intelligence
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=skill-intelligence

# File storage
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/tmp/skill-intelligence/uploads