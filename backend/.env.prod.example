# App
APP_ENV=production
APP_NAME="Skill Intelligence System"
APP_VERSION=0.1.0
DEBUG=false

# Security
SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Services (docker-compose.prod.yml sets these internally, do not change unless needed)
# DATABASE_URL=postgresql+asyncpg://skilluser:skillpass@db:5432/skilldb
# REDIS_URL=redis://redis:6379/0

# LLM
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_TIMEOUT_SECONDS=30

# LangSmith / tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=skill-intelligence

# File storage
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/tmp/skill-intelligence/uploads
